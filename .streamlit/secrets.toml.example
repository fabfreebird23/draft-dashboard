# Copy to .streamlit/secrets.toml and fill in what you need. All are OPTIONAL —
# the app runs without any secrets (using the UDK bookmarklet + public leagues).

# --- UDK server-side scrape ---------------------------------------------------
# Paste the WordPress session cookie from a browser logged into your UDK+ account
# (DevTools > Application > Cookies > thefantasyfootballers.com — copy the
# wordpress_logged_in_* / wordpress_sec_* pair as a single "name=value; name=value"
# string). Without it, use the one-click bookmarklet + CSV upload in the app.
udk_cookie = "wordpress_logged_in_xxx=...; wordpress_sec_xxx=..."

# --- ESPN private leagues -----------------------------------------------------
# From a browser logged into espn.com (DevTools > Application > Cookies > espn.com).
# Omit for public leagues. Can also be pasted per-session in the import form.
espn_s2 = "AEB..."
swid    = "{XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX}"

# --- Rankings persistence (optional) ------------------------------------------
# Without a token, rankings save to local data/ (resets on Streamlit Cloud
# restart). With a token + repo, they're committed to a data branch and reload
# on any device.
# github_token  = "github_pat_xxx"
# github_repo   = "youruser/draft-dashboard"
# github_branch = "draft-data"
